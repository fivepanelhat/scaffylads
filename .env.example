# --- Storage -----------------------------------------------------------------
# Leave BOTH unset to run on the local JSON store (data/app-data.json). That is
# the zero-setup path: no account, no sign-in, single user, and nothing leaves
# the machine. It is what the tests and CI use.
#
# Set BOTH to switch to hosted Postgres with sign-in and row-level security.
# Setting only one is treated as unset - see src/lib/store.ts.
#
# Both values are safe in the browser: the anon key is public by design and is
# constrained by the RLS policies in supabase/migrations/.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# NOTE: the service_role key is deliberately NOT used anywhere in this app.
# It bypasses RLS entirely. Do not add it here or to the hosting provider.

# --- AI ----------------------------------------------------------------------
# Optional. Without a key, "AI tidy notes" builds the draft locally and nothing
# leaves the device. With a key, the note text is sent to api.x.ai to be
# rewritten - server-side only.
XAI_API_KEY=
XAI_MODEL=grok-4.5

# Supabase (optional local JSON fallback when unset)
# Project: scaffylads (Oceania / Sydney)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Prefer service role on the server for demo CRUD (never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=
